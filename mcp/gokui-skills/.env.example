# Copy to .env (gitignored) and fill in. Never commit real values.

# Marketplace API base URL.
#   Local dev worker:        http://127.0.0.1:8787
#   Production (real money): https://gokui.mesalaunch.com
GOKUI_MARKETPLACE_URL=http://127.0.0.1:8787

# From POST /api/v1/agents/access (see main README). Scopes what this agent can spend per day.
GOKUI_AGENT_API_KEY=

# x402 network id. Use the Base Sepolia testnet id below until you intend to spend real funds.
#   Base Sepolia (testnet, fake money): eip155:84532
#   Base mainnet (REAL MONEY):          eip155:8453
GOKUI_X402_NETWORK=eip155:84532

# EVM private key that pays for invocations via x402.
# On mainnet this wallet needs real USDC and this key must be treated as a production secret
# (secret manager / env injection at deploy time) — never hardcode it, never commit it,
# never paste it into a prompt.
GOKUI_EVM_PRIVATE_KEY=
