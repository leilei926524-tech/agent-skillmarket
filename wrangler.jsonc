{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "expertos-agent-skillmarket",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-07-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": false,
  "routes": [],
  "assets": {
    "directory": "./web/out",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/.well-known/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "expertos-marketplace",
      "database_id": "a0fa7760-334b-4efb-a7cf-8dbd48d574e3",
      "migrations_dir": "worker/migrations"
    }
  ],
  "vars": {
    "APP_ENV": "production",
    "X402_NETWORK": "eip155:84532",
    "X402_FACILITATOR_URL": "https://api.cdp.coinbase.com/platform/v2/x402",
    "X402_PRICE_USD": "0.01",
    "X402_PAY_TO": "0xe16DC8bcA3D5E2fEF297929D10a632572cC9b431"
  }
}
